{
  "name": "agentflow",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start:app" : "cd app && pnpm dev",
    "start:server": "ts-node -r tsconfig-paths/register server/server.ts",
    "test": "ts-node -r tsconfig-paths/register examples/tests/run-all-tests.ts",
    "test:watch": "nodemon --exec ts-node -r tsconfig-paths/register examples/tests/run-all-tests.ts",
    "test:specific": "ts-node -r tsconfig-paths/register examples/tests/test-runner.ts",
    "type-check": "tsc --noEmit",
    "docs:dev": "cd docs && pnpm dev",
    "docs:build": "cd docs && pnpm build",
    "docs:preview": "cd docs && pnpm preview"
  },
  "keywords": [
    "agent",
    "workflow",
    "router",
    "planner",
    "executor",
    "dsl",
    "mastra"
  ],
  "author": "",
  "license": "ISC",
  "description": "工作流引擎 - 基于节点的工作流执行系统",
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@mastra/core": "^1.21.0",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "lodash": "^4.18.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsparticles/slim": "^3.9.1",
    "@tsparticles/vue3": "^3.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@vueuse/core": "^14.2.1",
    "mastra": "^1.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsparticles": "^3.9.1",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4"
  }
}
