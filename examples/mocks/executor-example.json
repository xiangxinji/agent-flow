{
  "id": "executor-workflow-example",
  "name": "执行器节点示例工作流",
  "version": "1.0.0",
  "root": "fetch-user-data",
  "nodes": [
    {
      "id": "fetch-user-data",
      "type": "function-call",
      "config": {
        "fnName": "fetchUserData",
        "input": {
          "userId": { "type": "literal", "value": 12345 },
          "includeProfile": { "type": "literal", "value": true }
        }
      }
    },
    {
      "id": "process-user-data",
      "type": "function-call",
      "config": {
        "fnName": "processUserData",
        "input": {
          "user": { "type": "ref", "path": "fetch-user-data.user" },
          "profile": { "type": "ref", "path": "fetch-user-data.profile" },
          "processingOptions": {
            "validate": { "type": "literal", "value": true },
            "enrich": { "type": "literal", "value": true }
          }
        }
      }
    },
    {
      "id": "calculate-user-score",
      "type": "function-call",
      "config": {
        "fnName": "calculateUserScore",
        "input": {
          "processedData": { "type": "ref", "path": "process-user-data.result" },
          "scoringModel": { "type": "literal", "value": "advanced" },
          "weights": {
            "activity": { "type": "literal", "value": 0.4 },
            "engagement": { "type": "literal", "value": 0.3 },
            "loyalty": { "type": "literal", "value": 0.3 }
          }
        }
      }
    },
    {
      "id": "generate-report",
      "type": "function-call",
      "config": {
        "fnName": "generateUserReport",
        "input": {
          "userData": { "type": "ref", "path": "fetch-user-data" },
          "processedData": { "type": "ref", "path": "process-user-data" },
          "score": { "type": "ref", "path": "calculate-user-score.score" },
          "reportFormat": { "type": "literal", "value": "detailed" },
          "includeCharts": { "type": "literal", "value": true }
        }
      }
    }
  ],
  "edges": [
    {
      "from": "fetch-user-data",
      "to": "process-user-data"
    },
    {
      "from": "process-user-data",
      "to": "calculate-user-score"
    },
    {
      "from": "calculate-user-score",
      "to": "generate-report"
    }
  ]
}
