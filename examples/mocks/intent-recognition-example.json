{
  "id": "intent-recognition-example",
  "name": "Intent Recognition Example",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "root",
      "type": "intent-recognition",
      "intentRecognition": {
        "agent": {
          "instructions": "You are an intent recognition system. Analyze the user's message and determine their intent from the provided list.",
          "model": "gpt-3.5-turbo"
        },
        "input": {
          "data": "$input.message"
        },
        "intentions": [
          {
            "name": "greeting",
            "target": "greeting-node"
          },
          {
            "name": "weather",
            "target": "weather-node"
          },
          {
            "name": "news",
            "target": "news-node"
          }
        ],
        "defaultTarget": "fallback-node"
      }
    },
    {
      "id": "greeting-node",
      "type": "tool",
      "tool": {
        "name": "greetUser",
        "input": {
          "name": "$input.name"
        }
      }
    },
    {
      "id": "weather-node",
      "type": "tool",
      "tool": {
        "name": "getWeather",
        "input": {
          "location": "$input.location"
        }
      }
    },
    {
      "id": "news-node",
      "type": "tool",
      "tool": {
        "name": "getNews",
        "input": {
          "category": "$input.category"
        }
      }
    },
    {
      "id": "fallback-node",
      "type": "tool",
      "tool": {
        "name": "handleFallback",
        "input": {
          "message": "$input.message"
        }
      }
    }
  ],
  "edges": [],
  "root": "root"
}
