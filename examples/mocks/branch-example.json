{
  "id": "branch-workflow-example",
  "name": "分支节点示例工作流",
  "version": "1.0.0",
  "root": "analyze-user",
  "nodes": [
    {
      "id": "analyze-user",
      "type": "function-call",
      "config": {
        "fnName": "analyzeUser",
        "input": {
          "userId": { "type": "ref", "path": "$.userId" }
        }
      }
    },
    {
      "id": "user-type-router",
      "type": "branch",
      "cases": [
        {
          "condition": "$.analyze-user.userType === 'vip'",
          "target": "handle-vip-user"
        },
        {
          "condition": "$.analyze-user.userType === 'regular'",
          "target": "handle-regular-user"
        },
        {
          "condition": "$.analyze-user.userType === 'guest'",
          "target": "handle-guest-user"
        }
      ],
      "next": "handle-unknown-user"
    },
    {
      "id": "handle-vip-user",
      "type": "function-call",
      "config": {
        "fnName": "handleVipUser",
        "input": {
          "user": { "type": "ref", "path": "analyze-user.user" },
          "benefits": { "type": "literal", "value": ["priority-support", "exclusive-discounts"] }
        }
      }
    },
    {
      "id": "handle-regular-user",
      "type": "function-call",
      "config": {
        "fnName": "handleRegularUser",
        "input": {
          "user": { "type": "ref", "path": "analyze-user.user" },
          "upgradeOffer": { "type": "literal", "value": true }
        }
      }
    },
    {
      "id": "handle-guest-user",
      "type": "function-call",
      "config": {
        "fnName": "handleGuestUser",
        "input": {
          "user": { "type": "ref", "path": "analyze-user.user" },
          "promptRegistration": { "type": "literal", "value": true }
        }
      }
    },
    {
      "id": "handle-unknown-user",
      "type": "function-call",
      "config": {
        "fnName": "handleUnknownUser",
        "input": {
          "user": { "type": "ref", "path": "analyze-user.user" },
          "logIssue": { "type": "literal", "value": true }
        }
      }
    }
  ],
  "edges": [
    {
      "from": "analyze-user",
      "to": "user-type-router"
    },
    {
      "from": "handle-vip-user",
      "to": "finalize-result"
    },
    {
      "from": "handle-regular-user",
      "to": "finalize-result"
    },
    {
      "from": "handle-guest-user",
      "to": "finalize-result"
    },
    {
      "from": "handle-unknown-user",
      "to": "finalize-result"
    }
  ]
}
